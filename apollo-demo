<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apollo Hospitals | Smart Clinic AI — Full Process Demo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --apollo-navy: #0A1F3F;
            --apollo-teal: #0E9488;
            --apollo-teal-light: #CCFBF1;
            --apollo-gold: #C8963E;
            --apollo-gold-light: #FDF2E0;
            --apollo-red: #C62828;
            --white: #FFFFFF;
            --bg: #F4F6F9;
            --gray-50: #F9FAFB;
            --gray-100: #F1F5F9;
            --gray-200: #E2E8F0;
            --gray-300: #CBD5E1;
            --gray-400: #94A3B8;
            --gray-500: #64748B;
            --gray-600: #475569;
            --gray-800: #1E293B;
            --text: #1E293B;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
            --shadow: 0 2px 8px rgba(0,0,0,0.06);
            --shadow-md: 0 6px 16px rgba(0,0,0,0.08);
            --shadow-lg: 0 16px 32px rgba(0,0,0,0.10);
            --shadow-xl: 0 24px 48px rgba(0,0,0,0.12);
            --radius-sm: 8px;
            --radius: 12px;
            --radius-lg: 16px;
            --radius-xl: 20px;
            --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            --font-xs: 0.68rem;
            --font-sm: 0.78rem;
            --font-base: 0.875rem;
            --font-md: 0.95rem;
            --font-lg: 1.05rem;
            --font-xl: 1.2rem;
            --font-2xl: 1.5rem;
            --font-3xl: 1.8rem;
        }
        *{margin:0;padding:0;box-sizing:border-box;} html{scroll-behavior:smooth;}
        body{font-family:'Inter',system-ui,-apple-system,sans-serif;background:var(--bg);color:var(--text);font-size:var(--font-base);line-height:1.6;min-height:100vh;-webkit-font-smoothing:antialiased;}

        /* ── COMMON HEADER (Dashboard) ── */
        .apollo-header {
            background: linear-gradient(135deg, #0A1F3F 0%, #132D56 40%, #1B4F8A 100%);
            color:#fff; padding:0.5rem 1.5rem; display:flex; align-items:center; justify-content:space-between;
            flex-wrap:wrap; gap:0.6rem; border-bottom:3px solid var(--apollo-gold); position:relative; overflow:hidden;
        }
        .apollo-header::after{ content:''; position:absolute; top:-50%; right:-5%; width:280px; height:280px;
            background:radial-gradient(circle, rgba(200,150,62,0.12) 0%, transparent 70%); border-radius:50%; pointer-events:none; }
        .header-left{display:flex; align-items:center; gap:0.75rem; z-index:1;}
        .header-logo{width:48px; height:48px; flex-shrink:0;} .header-logo svg{width:100%;height:100%;}
        .header-title-group{display:flex; flex-direction:column;}
        .header-main-title{font-weight:900; font-size:var(--font-xl); letter-spacing:-0.02em; line-height:1.2;}
        .header-main-title span{color:var(--apollo-gold);}
        .header-subtitle{font-size:0.6rem; font-weight:500; letter-spacing:0.06em; color:rgba(255,255,255,0.7); text-transform:uppercase;}
        .header-right{display:flex; align-items:center; gap:0.7rem; z-index:1; flex-wrap:wrap;}
        .header-badge{background:var(--apollo-red); padding:0.25rem 0.7rem; border-radius:50px; font-weight:700; font-size:0.6rem; animation:pulse-emergency 2s infinite; letter-spacing:0.04em; white-space:nowrap;}
        @keyframes pulse-emergency{0%,100%{box-shadow:0 0 0 0 rgba(198,40,40,0.5)}50%{box-shadow:0 0 0 10px rgba(198,40,40,0)}}
        .header-contact{font-size:0.6rem; font-weight:500; color:rgba(255,255,255,0.85); white-space:nowrap;}

        /* ── PAGE SWITCHER ── */
        .page-switcher{background:#fff; border-bottom:2px solid var(--gray-200); padding:0 1.5rem; display:flex; gap:0; align-items:stretch; box-shadow:var(--shadow-sm); position:sticky; top:0; z-index:99; overflow-x:auto;}
        .page-switcher button{padding:0.75rem 1.8rem; border:none; background:transparent; font-family:'Inter',sans-serif; font-weight:700; font-size:var(--font-sm); color:var(--gray-500); cursor:pointer; transition:var(--transition); white-space:nowrap; border-bottom:3px solid transparent; margin-bottom:-2px; display:flex; align-items:center; gap:0.5rem;}
        .page-switcher button:hover{color:var(--apollo-navy); background:var(--gray-50);}
        .page-switcher button.active-page-btn{color:var(--apollo-teal); border-bottom-color:var(--apollo-teal); background:var(--apollo-teal-light);}
        .page-container{display:none; animation:fadePageIn 0.4s ease-out;}
        .page-container.active-page{display:block;}
        @keyframes fadePageIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

        /* ── DASHBOARD LAYOUT ── */
        .main-layout{display:grid; grid-template-columns:62% 38%; gap:1.25rem; padding:1.25rem 1.5rem; max-width:1500px; margin:0 auto; min-height:calc(100vh - 210px);}
        .left-col{display:flex; flex-direction:column; gap:1.25rem;}
        .right-col{display:flex; flex-direction:column; gap:1.25rem;}
        .panel{background:#fff; border-radius:var(--radius-lg); padding:1.3rem 1.5rem; box-shadow:var(--shadow); border:1px solid var(--gray-200); transition:var(--transition); position:relative;}
        .panel.highlight-glow{border:2px solid var(--apollo-gold); box-shadow:0 0 0 6px rgba(200,150,62,0.07), var(--shadow-md); animation:glowPulse 2s ease-in-out infinite;}
        @keyframes glowPulse{0%,100%{box-shadow:0 0 0 6px rgba(200,150,62,0.07), var(--shadow-md)}50%{box-shadow:0 0 0 14px rgba(200,150,62,0.02), var(--shadow-lg)}}
        .panel-header{display:flex; align-items:center; gap:0.5rem; margin-bottom:0.85rem; flex-wrap:wrap;}
        .panel-icon{font-size:1.3rem; flex-shrink:0;}
        .panel-title{font-weight:700; font-size:var(--font-lg); color:var(--apollo-navy); letter-spacing:-0.01em;}
        .panel-badge{font-size:var(--font-xs); font-weight:700; padding:0.2rem 0.6rem; border-radius:50px; letter-spacing:0.03em;}
        .badge-live{background:#FEF2F2; color:#991B1B; border:1px solid #FECACA; animation:badgePulse 1.5s infinite;}
        @keyframes badgePulse{0%,100%{opacity:1}50%{opacity:0.5}}
        .badge-done{background:#ECFDF5; color:#065F46; border:1px solid #A7F3D0;}
        .badge-idle{background:var(--gray-100); color:var(--gray-500); border:1px solid var(--gray-200);}
        .chat-container{background:var(--gray-50); border-radius:var(--radius); padding:1rem; max-height:320px; min-height:140px; overflow-y:auto; display:flex; flex-direction:column; gap:0.5rem; border:1px solid var(--gray-200); scroll-behavior:smooth; font-size:var(--font-sm);}
        .chat-container::-webkit-scrollbar{width:5px;} .chat-container::-webkit-scrollbar-thumb{background:var(--gray-300); border-radius:10px;}
        .chat-bubble{max-width:84%; padding:0.55rem 0.8rem; border-radius:var(--radius); font-size:var(--font-sm); line-height:1.5; animation:fadeSlideUp 0.35s ease-out; word-break:break-word;}
        @keyframes fadeSlideUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
        .chat-bubble.doctor{align-self:flex-start; background:#fff; border:1.5px solid var(--gray-200); border-bottom-left-radius:4px; color:var(--text);}
        .chat-bubble.patient{align-self:flex-end; background:#E8F5F5; border:1.5px solid #C5E5E2; border-bottom-right-radius:4px; color:var(--apollo-navy);}
        .speaker-label{font-weight:700; font-size:0.6rem; text-transform:uppercase; letter-spacing:0.05em; display:block; margin-bottom:0.12rem; opacity:0.7;}
        .entity-highlight{background:#FEF08A; padding:0.08rem 0.3rem; border-radius:3px; font-weight:700; color:#92400E; border-bottom:2px solid #F59E0B; cursor:help; transition:var(--transition); white-space:nowrap;}
        .entity-highlight:hover{background:#FDE047; border-bottom-color:#D97706;}
        .chat-placeholder{text-align:center; color:var(--gray-400); padding:2rem 1rem; font-size:var(--font-sm); display:flex; flex-direction:column; align-items:center; gap:0.4rem;}
        .chat-placeholder i{font-size:2.2rem; opacity:0.3;}
        .rx-widget{background:linear-gradient(135deg,#FFFBF0,#FFF7ED); border:2px dashed #FCD34D; border-radius:var(--radius); padding:0.65rem 1rem; margin-top:0.5rem; font-size:var(--font-sm); font-weight:600; color:#92400E; display:flex; align-items:center; gap:0.5rem; min-height:40px; flex-wrap:wrap; transition:var(--transition);}
        .rx-pill{background:#fff; border:1.5px solid #FCD34D; border-radius:50px; padding:0.25rem 0.65rem; font-weight:700; font-size:var(--font-xs); color:#B45309; white-space:nowrap;}
        .form-overlay{background:#fff; border-radius:var(--radius-lg); padding:1.3rem 1.5rem; box-shadow:var(--shadow-md); border:2px solid var(--apollo-teal); border-top:4px solid var(--apollo-teal); display:none; transition:var(--transition);}
        .form-overlay.visible{display:block; animation:slideDown 0.4s ease-out;}
        @keyframes slideDown{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:translateY(0)}}
        .form-row{display:flex; gap:0.7rem; flex-wrap:wrap; align-items:flex-end;}
        .form-group{display:flex; flex-direction:column; gap:0.2rem; flex:1; min-width:100px;}
        .form-group label{font-weight:700; font-size:0.6rem; color:var(--gray-600); text-transform:uppercase; letter-spacing:0.04em;}
        .form-group input{padding:0.5rem 0.7rem; border:2px solid var(--gray-300); border-radius:var(--radius-sm); font-family:'Inter',sans-serif; font-size:var(--font-sm); transition:var(--transition); background:var(--gray-50); color:var(--text); outline:none;}
        .form-group input:focus{border-color:var(--apollo-teal); box-shadow:0 0 0 4px rgba(14,148,136,0.07); background:#fff;}
        .btn{padding:0.55rem 1.2rem; border-radius:50px; font-weight:700; font-size:var(--font-sm); cursor:pointer; border:none; transition:var(--transition); font-family:'Inter',sans-serif; letter-spacing:0.01em; display:inline-flex; align-items:center; gap:0.4rem; white-space:nowrap; position:relative; overflow:hidden;}
        .btn-teal{background:var(--apollo-teal); color:#fff; box-shadow:0 3px 12px rgba(14,148,136,0.3);}
        .btn-teal:hover{background:#0F766E; box-shadow:0 6px 20px rgba(14,148,136,0.4); transform:translateY(-2px);}
        .btn-gold{background:var(--apollo-gold); color:#fff; box-shadow:0 3px 12px rgba(200,150,62,0.3); font-weight:800;}
        .btn-gold:hover{background:#B8862D; box-shadow:0 6px 20px rgba(200,150,62,0.45); transform:translateY(-2px);}
        .btn:disabled{background:var(--gray-300); cursor:not-allowed; box-shadow:none; transform:none;}
        .btn-spinner{display:none; width:15px; height:15px; border:2px solid rgba(255,255,255,0.4); border-top-color:#fff; border-radius:50%; animation:spin 0.7s linear infinite;}
        .btn.loading .btn-spinner{display:inline-block;} .btn.loading{pointer-events:none; opacity:0.8;}
        @keyframes spin{to{transform:rotate(360deg)}}
        .ripple-effect{position:absolute; border-radius:50%; background:rgba(255,255,255,0.5); transform:scale(0); animation:ripple 0.6s ease-out; pointer-events:none;}
        @keyframes ripple{to{transform:scale(4);opacity:0}}
        .patient-card{background:#fff; border-radius:var(--radius-lg); padding:1.3rem 1.5rem; box-shadow:var(--shadow-md); border:1px solid var(--gray-200); border-left:5px solid var(--apollo-teal); min-height:80px; display:flex; flex-direction:column; justify-content:center; transition:var(--transition);}
        .patient-card.empty-card{border-left-color:var(--gray-300); opacity:0.6;}
        .card-eyebrow{font-size:0.55rem; text-transform:uppercase; letter-spacing:0.07em; color:var(--gray-400); font-weight:700; margin-bottom:0.15rem;}
        .patient-name-lg{font-weight:800; font-size:var(--font-2xl); color:var(--apollo-navy); letter-spacing:-0.02em;}
        .patient-meta{font-size:var(--font-sm); color:var(--gray-600); margin-top:0.1rem; display:flex; gap:0.8rem; flex-wrap:wrap;}
        .token-chip{display:inline-block; background:var(--apollo-teal-light); color:#0F766E; font-weight:800; padding:0.15rem 0.6rem; border-radius:50px; font-size:var(--font-xs);}
        .empty-state-text{color:var(--gray-400); font-style:italic; text-align:center; font-size:var(--font-sm);}
        .queue-list{list-style:none; display:flex; flex-direction:column; gap:0.4rem; max-height:220px; overflow-y:auto;}
        .queue-list::-webkit-scrollbar{width:4px;} .queue-list::-webkit-scrollbar-thumb{background:var(--gray-300); border-radius:10px;}
        .queue-item{display:flex; align-items:center; gap:0.55rem; padding:0.55rem 0.75rem; border-radius:var(--radius); border:2px solid var(--gray-200); cursor:pointer; transition:var(--transition); background:#fff;}
        .queue-item:hover{border-color:var(--apollo-teal); box-shadow:var(--shadow-md); transform:translateX(3px);}
        .queue-item.next-in-line{border-color:#10B981; border-width:2.5px; background:#F0FDF9; box-shadow:0 0 0 5px rgba(16,185,129,0.05);}
        .queue-token-num{font-weight:900; font-size:var(--font-lg); color:var(--apollo-teal); min-width:30px; text-align:center; flex-shrink:0;}
        .queue-info{flex:1; min-width:0;} .queue-name{font-weight:700; font-size:var(--font-sm); color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
        .queue-concern{font-size:var(--font-xs); color:var(--gray-500); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;}
        .queue-wait-badge{font-weight:700; font-size:0.6rem; color:#B45309; white-space:nowrap; flex-shrink:0; background:#FEF3C7; padding:0.15rem 0.45rem; border-radius:50px;}
        .btn-next-full{width:100%; padding:0.7rem; font-size:var(--font-md); font-weight:800; background:var(--apollo-teal); color:#fff; border:none; border-radius:50px; cursor:pointer; transition:var(--transition); letter-spacing:0.02em; box-shadow:0 4px 16px rgba(14,148,136,0.35); font-family:'Inter',sans-serif;}
        .btn-next-full:hover{background:#0F766E; box-shadow:0 8px 24px rgba(14,148,136,0.5); transform:translateY(-2px);}
        .btn-next-full:disabled{background:var(--gray-300); cursor:not-allowed; box-shadow:none; transform:none; opacity:0.5;}
        .flow-mini{background:#fff; border-radius:var(--radius-lg); padding:1rem 1.2rem; box-shadow:var(--shadow); border:1px solid var(--gray-200); text-align:center;}
        .flow-mini .flow-title{font-weight:700; font-size:0.6rem; color:var(--gray-500); text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.5rem;}
        .flow-dots-row{display:flex; align-items:center; justify-content:center; gap:0.25rem; flex-wrap:wrap;}
        .flow-dot-mini{width:14px; height:14px; border-radius:50%; background:var(--gray-200); flex-shrink:0; transition:var(--transition);}
        .flow-dot-mini.active-dot{background:var(--apollo-teal); box-shadow:0 0 10px rgba(14,148,136,0.5); animation:bounceDot 0.6s ease-out;}
        .flow-dot-mini.done-dot{background:#10B981;}
        @keyframes bounceDot{0%,100%{transform:scale(1)}40%{transform:scale(1.5)}}
        .flow-arrow-mini{color:var(--gray-300); font-size:0.45rem;}

        /* ── MIND MAP PAGE STYLES ── */
        .mindmap-page{padding:1.5rem; max-width:1400px; margin:0 auto;}
        .mindmap-header{background:var(--apollo-navy); color:#fff; padding:1rem 1.5rem; border-radius:var(--radius-xl) var(--radius-xl) 0 0; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:0.5rem; box-shadow:var(--shadow-md);}
        .mindmap-header h2{font-weight:900; font-size:var(--font-2xl); letter-spacing:-0.02em; color:var(--apollo-gold);}
        .mindmap-header .back-link{background:rgba(255,255,255,0.1); padding:0.45rem 1rem; border-radius:50px; font-weight:600; font-size:var(--font-xs); color:#fff; cursor:pointer; transition:var(--transition); border:1px solid rgba(255,255,255,0.2); display:inline-flex; align-items:center; gap:0.3rem; text-decoration:none;}
        .mindmap-header .back-link:hover{background:rgba(255,255,255,0.2);}
        .mindmap-grid{display:grid; grid-template-columns:repeat(3,1fr); gap:2rem 1.5rem; margin-top:1.5rem; position:relative;}
        .mindmap-node{background:#fff; border-radius:var(--radius-xl); box-shadow:var(--shadow-md); border:2px solid var(--gray-200); overflow:hidden; transition:var(--transition); display:flex; flex-direction:column;}
        .mindmap-node:hover{transform:translateY(-4px); box-shadow:var(--shadow-xl); border-color:var(--apollo-teal);}
        .node-img-placeholder{width:100%; height:180px; background:linear-gradient(135deg,#F8FAFC 0%,#E2E8F0 100%); display:flex; flex-direction:column; align-items:center; justify-content:center; border-bottom:2px dashed var(--gray-300); position:relative; overflow:hidden;}
        .node-img-placeholder .placeholder-icon{font-size:3rem; color:var(--gray-400); opacity:0.6; margin-bottom:0.3rem;}
        .node-img-placeholder .placeholder-text{font-size:0.6rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:var(--gray-400); background:rgba(255,255,255,0.8); padding:0.2rem 0.7rem; border-radius:50px; border:1px solid var(--gray-300);}
        .node-img-placeholder .placeholder-dims{position:absolute; bottom:6px; right:10px; font-size:0.5rem; color:var(--gray-400); font-weight:500; background:rgba(255,255,255,0.7); padding:0.1rem 0.4rem; border-radius:4px;}
        .node-body{padding:1rem 1.2rem; flex:1; display:flex; flex-direction:column; gap:0.4rem;}
        .node-step-num{font-weight:900; font-size:0.6rem; text-transform:uppercase; letter-spacing:0.08em; color:var(--apollo-teal);}
        .node-step-title{font-weight:800; font-size:var(--font-lg); color:var(--apollo-navy); letter-spacing:-0.01em;}
        .node-step-desc{font-size:var(--font-xs); color:var(--gray-500); line-height:1.5;}
        .node-step-tags{display:flex; gap:0.35rem; flex-wrap:wrap; margin-top:0.3rem;}
        .node-tag{font-size:0.55rem; font-weight:700; padding:0.15rem 0.5rem; border-radius:50px; background:var(--apollo-teal-light); color:#0F766E; letter-spacing:0.03em;}
        .node-tag.gold-tag{background:var(--apollo-gold-light); color:#7C5E1A;}

        /* ── TOAST ── */
        .toast-container{position:fixed; bottom:1.5rem; right:1.5rem; z-index:9999; display:flex; flex-direction:column-reverse; gap:0.5rem; pointer-events:none;}
        .toast{background:var(--apollo-navy); color:#fff; padding:0.65rem 1rem; border-radius:var(--radius); font-weight:600; font-size:var(--font-sm); box-shadow:var(--shadow-xl); animation:toastIn 0.4s ease-out, toastOut 0.35s ease-in forwards; animation-delay:0s, 3.8s; pointer-events:auto; display:flex; align-items:center; gap:0.5rem; max-width:440px; border-left:4px solid var(--apollo-gold);}
        .toast.whatsapp-toast{border-left-color:#25D366; background:#075E54;}
        .toast.success-toast{border-left-color:#10B981;}
        @keyframes toastIn{from{opacity:0;transform:translateX(50px)}to{opacity:1;transform:translateX(0)}}
        @keyframes toastOut{from{opacity:1;transform:translateX(0)}to{opacity:0;transform:translateX(50px)}}

        /* ── RESPONSIVE ── */
        @media(max-width:1100px){.main-layout{grid-template-columns:1fr; padding:1rem;} .mindmap-grid{grid-template-columns:repeat(2,1fr); gap:1.25rem;} }
        @media(max-width:700px){.mindmap-grid{grid-template-columns:1fr; gap:1rem;} .chat-container{max-height:220px;} .queue-list{max-height:150px;} .form-row{flex-direction:column;} .mindmap-node .node-img-placeholder{height:140px;} }
    </style>
</head>
<body>
    <!-- ═══════════ APOLLO HEADER (shared) ═══════════ -->
    <header class="apollo-header" id="apolloHeader">
        <div class="header-left">
            <div class="header-logo">
                <svg viewBox="0 0 50 50" fill="none"><rect width="50" height="50" rx="12" fill="#0A1F3F"/><rect x="10" y="13" width="30" height="24" rx="3" fill="none" stroke="white" stroke-width="3.5"/><line x1="16" y1="19" x2="34" y2="19" stroke="white" stroke-width="2.5" stroke-linecap="round"/><line x1="16" y1="24" x2="34" y2="24" stroke="white" stroke-width="2.5" stroke-linecap="round"/><line x1="16" y1="29" x2="28" y2="29" stroke="white" stroke-width="2.5" stroke-linecap="round"/><circle cx="39" cy="39" r="8" fill="#C8963E"/><text x="39" y="42.5" text-anchor="middle" fill="white" font-size="9" font-weight="900">+</text></svg>
            </div>
            <div class="header-title-group">
                <div class="header-main-title">Apollo <span>Smart Clinic AI</span></div>
                <div class="header-subtitle">Full Process Demonstration • सम्पूर्ण प्रक्रिया डेमो</div>
            </div>
        </div>
        <div class="header-right">
            <span class="header-contact"><i class="fa-solid fa-phone"></i> +91 44 2829 0200</span>
            <span class="header-contact"><i class="fa-solid fa-location-dot"></i> 70+ Centers</span>
            <span class="header-badge">🆘 EMERGENCY: 1066</span>
        </div>
    </header>

    <!-- ═══════════ PAGE SWITCHER ═══════════ -->
    <div class="page-switcher" id="pageSwitcher">
        <button class="active-page-btn" data-page="dashboard"><i class="fa-solid fa-stethoscope"></i> Live Dashboard</button>
        <button data-page="mindmap"><i class="fa-solid fa-brain"></i> Full Process Mind Map</button>
    </div>

    <!-- ═══════════ PAGE 1: DASHBOARD ═══════════ -->
    <div class="page-container active-page" id="pageDashboard">
