                        <button class="btn btn-teal" id="btnAutoDemo" style="flex:1;">▶️ Auto Demo</button>
                        <button class="btn" id="btnReset" style="flex:1; background:#fff; border:1.5px solid #CBD5E1; color:#64748B;">🔄 Reset</button>
                    </div>
                </div>
                <div class="flow-mini">
                    <div class="flow-title">🔄 Live Process Flow</div>
                    <div class="flow-dots-row" id="flowMiniDots">
                        <span class="flow-dot-mini active-dot" data-fs="1"></span><span class="flow-arrow-mini">→</span>
                        <span class="flow-dot-mini" data-fs="2"></span><span class="flow-arrow-mini">→</span>
                        <span class="flow-dot-mini" data-fs="3"></span><span class="flow-arrow-mini">→</span>
                        <span class="flow-dot-mini" data-fs="4"></span><span class="flow-arrow-mini">→</span>
                        <span class="flow-dot-mini" data-fs="5"></span><span class="flow-arrow-mini">→</span>
                        <span class="flow-dot-mini" data-fs="6"></span>
                    </div>
                    <div style="font-size:0.55rem;color:var(--gray-400);margin-top:0.3rem;">Step <span id="flowStepLabel">1</span> of 6 — <span id="flowStepName">Patient Check‑in</span></div>
                </div>
            </div>
        </div>
    </div>

