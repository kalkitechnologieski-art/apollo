    <!-- ═══════════ TOAST CONTAINER ═══════════ -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // ──────────────────────────────────────
            // STATE (TTS removed)
            // ──────────────────────────────────────
            const state = {
                currentStep: 1,
                currentPatient: null,
                waitingQueue: [
                    { token: 12, name: 'Ravi Singh', age: 34, concern: 'Persistent cough & fever', wait_time: '25 mins' },
                    { token: 13, name: 'Anita Desai', age: 52, concern: 'Joint pain in knees', wait_time: '15 mins' },
                    { token: 14, name: 'Vikram Patel', age: 28, concern: 'Allergic skin rash', wait_time: '5 mins' },
                ],
                isTranscribing: false,
                transcriptionTimeoutIds: [],
                extractedMeds: [],
                formVisible: false,
                autoDemoActive: false,
                autoDemoTimeoutIds: [],
            };

            const stepNames = ['Patient Check‑in', 'AI Triage', 'Token Queue', 'Live Consultation', 'Prescription AI', 'WhatsApp Report'];
            const mockScript = [
                { speaker: 'Doctor', text: 'Good morning, Mr. Ravi. Tell me about your symptoms.' },
                { speaker: 'Patient', text: 'Doctor, 5 days se dry cough hai. Raat mein bohot takleef hoti hai. (5 days dry cough, worse at night.)' },
                { speaker: 'Doctor', text: 'Any fever or body pain?' },
                { speaker: 'Patient', text: 'Haan, evening mein mild fever aata hai. (Yes, mild evening fever.)' },
                { speaker: 'Doctor', text: 'I am prescribing Azithromycin 500mg once daily for 3 days. Also Paracetamol 650mg if fever exceeds 101°F.' },
                { speaker: 'Patient', text: 'Okay doctor. Aur kuch? (Anything else?)' },
                { speaker: 'Doctor', text: 'Take warm fluids. Avoid cold items. I am also sharing a diet chart via WhatsApp.' },
            ];

            // ──────────────────────────────────────
            // DOM REFS
            // ──────────────────────────────────────
            const $ = (s) => document.querySelector(s);
            const $$ = (s) => document.querySelectorAll(s);

            const pageSwitcherBtns = $$('.page-switcher button');
            const pageDashboard = $('#pageDashboard');
            const pageMindmap = $('#pageMindmap');
            const btnAutoDemo = $('#btnAutoDemo');
            const btnReset = $('#btnReset');
            const transcriptionBadge = $('#transcriptionBadge');
            const chatContainer = $('#chatContainer');
            const chatPlaceholder = $('#chatPlaceholder');
            const rxWidget = $('#rxWidget');
            const rxContent = $('#rxContent');
            const patientFormOverlay = $('#patientFormOverlay');
            const patientNameInput = $('#patient_name');
            const patientAgeInput = $('#patient_age');
            const patientWhatsappInput = $('#patient_whatsapp');
            const sendReportBtn = $('#sendReportBtn');
            const currentPatientCard = $('#currentPatientCard');
            const currentPatientContent = $('#currentPatientContent');
            const queueList = $('#queueList');
            const nextPatientBtn = $('#nextPatientBtn');
            const flowMiniDots = $('#flowMiniDots');
            const flowStepLabel = $('#flowStepLabel');
            const flowStepName = $('#flowStepName');
            const toastContainer = $('#toastContainer');
            const consultationPanel = $('#consultationPanel');
            const backToDashboardBtn = $('#backToDashboard');

            // ──────────────────────────────────────
            // PAGE SWITCHING
            // ──────────────────────────────────────
            function switchPage(pageName) {
                pageDashboard.classList.toggle('active-page', pageName === 'dashboard');
                pageMindmap.classList.toggle('active-page', pageName === 'mindmap');
                pageSwitcherBtns.forEach(btn => {
                    btn.classList.toggle('active-page-btn', btn.dataset.page === pageName);
                });
            }

            pageSwitcherBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    switchPage(this.dataset.page);
                });
            });
            backToDashboardBtn.addEventListener('click', () => switchPage('dashboard'));

            // ──────────────────────────────────────
            // INIT
            // ──────────────────────────────────────
            function init() {
                renderQueue();
                updateAllUI();
                setupEventListeners();
                showToast('👋 Welcome to <strong>Apollo Smart Clinic AI</strong>. Use tabs to explore Dashboard & Mind Map.', 'info');
            }

            function setupEventListeners() {
                btnAutoDemo.addEventListener('click', toggleAutoDemo);
                btnReset.addEventListener('click', resetEverything);
                nextPatientBtn.addEventListener('click', handleNextPatient);
                nextPatientBtn.addEventListener('mousedown', addRipple);
                sendReportBtn.addEventListener('click', handleSendReport);
                sendReportBtn.addEventListener('mousedown', addRipple);
                patientWhatsappInput.addEventListener('input', () => {
                    sendReportBtn.disabled = !patientWhatsappInput.value.trim() || !state.currentPatient;
                });
            }

            // ──────────────────────────────────────
            // UI UPDATES
            // ──────────────────────────────────────
            function updateAllUI() {
                updateStepperUI();
                updateNextButtonState();
                updateTranscriptionBadge();
                updateCurrentPatientCardUI();
            }

            function updateStepperUI() {
                const dots = $$('.flow-dot-mini');
                dots.forEach((dot, i) => {
                    const s = i + 1;
                    dot.classList.remove('active-dot', 'done-dot');
                    if (s < state.currentStep) dot.classList.add('done-dot');
                    if (s === state.currentStep) dot.classList.add('active-dot');
                });
                flowStepLabel.textContent = state.currentStep;
                flowStepName.textContent = stepNames[state.currentStep - 1] || '';
            }

            function updateTranscriptionBadge() {
                if (state.isTranscribing) {
                    transcriptionBadge.textContent = '🔴 LIVE';
                    transcriptionBadge.className = 'panel-badge badge-live';
                } else if (state.currentPatient && !state.isTranscribing && state.formVisible) {
                    transcriptionBadge.textContent = '✅ Done';
                    transcriptionBadge.className = 'panel-badge badge-done';
                } else {
                    transcriptionBadge.textContent = '⏸ Idle';
                    transcriptionBadge.className = 'panel-badge badge-idle';
                }
            }

            function updateNextButtonState() {
                nextPatientBtn.disabled = state.waitingQueue.length === 0 || state.isTranscribing;
                nextPatientBtn.style.opacity = (state.waitingQueue.length === 0 || state.isTranscribing) ? '0.45' : '1';
            }

            function updateCurrentPatientCardUI() {
                if (!state.currentPatient) {
                    currentPatientCard.classList.add('empty-card');
                    currentPatientContent.innerHTML = '<div class="empty-state-text">Waiting for next patient...</div>';
                } else {
                    currentPatientCard.classList.remove('empty-card');
                    const p = state.currentPatient;
                    currentPatientContent.innerHTML = `
                        <div class="patient-name-lg">${p.name}</div>
                        <div class="patient-meta">
                            <span>🎂 Age: ${p.age}</span><span>🩺 ${p.concern}</span>
                            <span class="token-chip">Token #${p.token}</span>
                        </div>`;
                }
            }

            // ──────────────────────────────────────
            // QUEUE
            // ──────────────────────────────────────
            function renderQueue() {
                queueList.innerHTML = '';
                if (state.waitingQueue.length === 0) {
                    queueList.innerHTML = '<li style="text-align:center;color:#94A3B8;padding:1.5rem;font-style:italic;">All patients seen. Queue empty.</li>';
                } else {
                    state.waitingQueue.forEach((patient, index) => {
                        const li = document.createElement('li');
                        li.className = 'queue-item' + (index === 0 ? ' next-in-line' : '');
                        li.dataset.token = patient.token;
                        li.innerHTML = `
                            <span style="color:#CBD5E1;cursor:grab;font-size:0.8rem;">⋮⋮</span>
                            <span class="queue-token-num">#${patient.token}</span>
                            <div class="queue-info"><div class="queue-name">${patient.name}</div><div class="queue-concern">${patient.concern}</div></div>
                            <span class="queue-wait-badge">⏱ ${patient.wait_time}</span>`;
                        li.addEventListener('click', () => {
                            if (!state.isTranscribing && !state.autoDemoActive) loadSpecificPatient(patient.token);
                        });
                        queueList.appendChild(li);
                    });
                }
                updateNextButtonState();
            }

            // ──────────────────────────────────────
            // NEXT PATIENT
            // ──────────────────────────────────────
            function handleNextPatient() {
                if (state.isTranscribing) { showToast('⚠️ Please wait — consultation is still recording.', 'info'); return; }
                if (state.waitingQueue.length === 0) { showToast('📭 No more patients in the queue.', 'info'); return; }
                clearAllTranscriptionTimeouts();
                const patient = state.waitingQueue.shift();
                state.currentPatient = patient;
                state.extractedMeds = [];
                state.formVisible = false;
                rxContent.innerHTML = '<span style="color:#94A3B8;font-weight:400;">Listening for prescription details...</span>';
                patientFormOverlay.classList.remove('visible');
                patientNameInput.value = ''; patientAgeInput.value = ''; patientWhatsappInput.value = '';
                sendReportBtn.disabled = true; sendReportBtn.classList.remove('loading');
                updateCurrentPatientCardUI(); renderQueue();
                chatContainer.innerHTML = ''; chatPlaceholder.style.display = 'none';
                state.isTranscribing = true; state.currentStep = 4; updateAllUI();
                consultationPanel.classList.add('highlight-glow');
                showToast(`📱 <strong>WhatsApp Alert:</strong> Token #${patient.token} — "Your turn! Please proceed to Room 201." 🗺️ <em>Google Maps attached.</em>`, 'whatsapp-toast');
                startTranscription(patient);
            }

            function loadSpecificPatient(token) {
                const index = state.waitingQueue.findIndex(p => p.token === token);
                if (index === -1) return;
                clearAllTranscriptionTimeouts();
                const patient = state.waitingQueue.splice(index, 1)[0];
                state.currentPatient = patient; state.extractedMeds = []; state.formVisible = false;
                rxContent.innerHTML = '<span style="color:#94A3B8;font-weight:400;">Listening for prescription details...</span>';
                patientFormOverlay.classList.remove('visible');
                patientNameInput.value = ''; patientAgeInput.value = ''; patientWhatsappInput.value = '';
                sendReportBtn.disabled = true; sendReportBtn.classList.remove('loading');
                updateCurrentPatientCardUI(); renderQueue();
                chatContainer.innerHTML = ''; chatPlaceholder.style.display = 'none';
                state.isTranscribing = true; state.currentStep = 4; updateAllUI();
                consultationPanel.classList.add('highlight-glow');
                showToast(`📱 <strong>WhatsApp Alert:</strong> Token #${patient.token} — "Your turn!"`, 'whatsapp-toast');
                startTranscription(patient);
            }

            // ──────────────────────────────────────
            // TRANSCRIPTION
            // ──────────────────────────────────────
            function startTranscription(patient) {
                state.isTranscribing = true; updateAllUI();
                chatContainer.innerHTML = '';
                rxContent.innerHTML = '<span style="color:#94A3B8;font-weight:400;">Listening for prescription details...</span>';
                const allWords = [];
                mockScript.forEach(entry => {
                    const words = entry.text.split(/\s+/);
                    words.forEach((w, idx) => allWords.push({ speaker: entry.speaker, word: w, isFirst: idx === 0, fullLineText: entry.text }));
                });
                let idx = 0, currentBubble = null, currentSpeaker = null;
                function streamWord() {
                    if (idx >= allWords.length) { finishTranscription(patient); return; }
                    const entry = allWords[idx];
                    if (entry.isFirst || entry.speaker !== currentSpeaker) {
                        currentSpeaker = entry.speaker;
                        currentBubble = document.createElement('div');
                        currentBubble.className = 'chat-bubble ' + (entry.speaker === 'Doctor' ? 'doctor' : 'patient');
                        const label = document.createElement('span');
                        label.className = 'speaker-label';
                        label.textContent = entry.speaker === 'Doctor' ? '👨‍⚕️ Doctor' : '🧑‍🦰 Patient';
                        currentBubble.appendChild(label);
                        const msgSpan = document.createElement('span'); msgSpan.className = 'msg-text';
                        currentBubble.appendChild(msgSpan); chatContainer.appendChild(currentBubble);
                    }
                    const msgSpan = currentBubble.querySelector('.msg-text');
                    const highlighted = highlightEntity(entry.word);
                    if (highlighted !== entry.word) {
                        const span = document.createElement('span'); span.innerHTML = ' ' + highlighted;
                        msgSpan.appendChild(span); extractMedFromWord(entry.word);
                    } else { msgSpan.appendChild(document.createTextNode(' ' + entry.word)); }
                    updateRxWidget(); chatContainer.scrollTop = chatContainer.scrollHeight;
                    idx++;
                    const tid = setTimeout(streamWord, 260 + Math.random() * 90);
                    state.transcriptionTimeoutIds.push(tid);
                }
                const initTid = setTimeout(streamWord, 350); state.transcriptionTimeoutIds.push(initTid);
            }

            function highlightEntity(word) {
                const clean = word.replace(/[.,;:!?]+$/, ''); const suffix = word.slice(clean.length);
                if (/\d+mg/i.test(clean) || /\d+ml/i.test(clean) || /\d+mcg/i.test(clean)) return `<mark class="entity-highlight" title="Dosage">${clean}</mark>${suffix}`;
                if (/^(Azithromycin|Paracetamol|Amoxicillin|Ibuprofen|Cetirizine|Omeprazole|Metformin)$/i.test(clean)) return `<mark class="entity-highlight" title="Medicine">${clean}</mark>${suffix}`;
                if (/^(once|twice|three\s+times)\s+daily$/i.test(clean) || /^daily$/i.test(clean)) return `<mark class="entity-highlight" title="Instruction">${clean}</mark>${suffix}`;
                return word;
            }

            function extractMedFromWord(word) {
                const clean = word.replace(/[.,;:!?]+$/, '');
                const medMatch = clean.match(/^(Azithromycin|Paracetamol|Amoxicillin|Ibuprofen|Cetirizine)$/i);
                const doseMatch = clean.match(/^(\d+mg|\d+ml|\d+mcg)$/i);
                if (medMatch && !state.extractedMeds.find(m => m.name.toLowerCase() === medMatch[1].toLowerCase())) state.extractedMeds.push({ name: medMatch[1], dosage: '', instruction: '' });
                if (doseMatch && state.extractedMeds.length > 0) { const last = state.extractedMeds[state.extractedMeds.length-1]; if (!last.dosage) last.dosage = doseMatch[1]; }
                const freqMatch = clean.match(/^(once|twice|three\s+times)\s+daily\s+for\s+(\d+)\s+days?$/i);
                if (freqMatch && state.extractedMeds.length > 0) state.extractedMeds[state.extractedMeds.length-1].instruction = freqMatch[0];
            }

            function updateRxWidget() {
                if (state.extractedMeds.length === 0) { rxContent.innerHTML = '<span style="color:#94A3B8;font-weight:400;">Listening for prescription details...</span>'; return; }
                rxContent.innerHTML = state.extractedMeds.map(m => {
                    let t = `<span class="rx-pill">💊 <strong>${m.name}</strong>`;
                    if (m.dosage) t += ` ${m.dosage}`; if (m.instruction) t += ` — ${m.instruction}`;
                    return t + '</span>';
                }).join(' ');
            }

            function finishTranscription(patient) {
                state.isTranscribing = false; state.currentStep = 5; updateAllUI();
                clearAllTranscriptionTimeouts(); consultationPanel.classList.remove('highlight-glow');
                updateRxWidget();
                showToast('✅ <strong>Transcription complete!</strong> Prescription extracted. Please fill the form.', 'success-toast');
                setTimeout(() => {
                    patientFormOverlay.classList.add('visible'); state.formVisible = true;
                    patientNameInput.value = patient.name || ''; patientAgeInput.value = patient.age || '';
                    patientWhatsappInput.value = ''; sendReportBtn.disabled = true; sendReportBtn.classList.remove('loading');
                    state.currentStep = 6; updateAllUI();
                    patientFormOverlay.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }, 600);
            }

            function clearAllTranscriptionTimeouts() { state.transcriptionTimeoutIds.forEach(id => clearTimeout(id)); state.transcriptionTimeoutIds = []; }

            // ──────────────────────────────────────
            // SEND REPORT
            // ──────────────────────────────────────
            function handleSendReport() {
                if (!state.currentPatient) return;
                const whatsapp = patientWhatsappInput.value.trim();
                if (!whatsapp) { showToast('⚠️ Please enter WhatsApp number.', 'info'); return; }
                sendReportBtn.classList.add('loading'); sendReportBtn.disabled = true;
                setTimeout(() => {
                    const pname = patientNameInput.value || state.currentPatient.name;
                    const page = patientAgeInput.value || state.currentPatient.age;
                    const pdfText = `Apollo Prescription - ${pname} | Token #${state.currentPatient.token}\n${state.extractedMeds.map(m=>m.name+' '+m.dosage+' '+m.instruction).join('\n')}`;
                    const blob = new Blob([pdfText], {type:'application/pdf'});
                    const url = URL.createObjectURL(blob); const a = document.createElement('a');
                    a.href = url; a.download = `Apollo_Prescription_${pname.replace(/\s+/g,'_')}_T${state.currentPatient.token}.pdf`;
                    document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
                    sendReportBtn.classList.remove('loading'); sendReportBtn.disabled = false;
                    showToast(`📄 PDF sent via WhatsApp to ${whatsapp.slice(0,5)}**** ✅`, 'whatsapp-toast');
                    patientFormOverlay.classList.remove('visible'); state.formVisible = false; state.currentStep = 6; updateAllUI();
                }, 2000);
            }

            // ──────────────────────────────────────
            // AUTO DEMO
            // ──────────────────────────────────────
            function toggleAutoDemo() { state.autoDemoActive ? stopAutoDemo() : startAutoDemo(); }
            function startAutoDemo() {
                state.autoDemoActive = true; btnAutoDemo.textContent = '⏸ Stop Demo'; btnAutoDemo.style.background='#C62828'; btnAutoDemo.style.color='#fff';
                showToast('▶️ Auto Demo Started!', 'info'); resetEverythingSilent(); runAutoDemoStep(0);
            }
            function stopAutoDemo() {
                state.autoDemoActive = false; btnAutoDemo.textContent = '▶️ Auto Demo'; btnAutoDemo.style.background=''; btnAutoDemo.style.color='';
                state.autoDemoTimeoutIds.forEach(id=>clearTimeout(id)); state.autoDemoTimeoutIds=[]; clearAllTranscriptionTimeouts();
                state.isTranscribing=false; updateAllUI(); consultationPanel.classList.remove('highlight-glow');
                showToast('⏸ Demo stopped.', 'info');
            }
            function runAutoDemoStep(stepIndex) {
                if (!state.autoDemoActive) return;
                const steps = [
                    ()=>{ state.currentStep=1; updateAllUI(); showToast('Step 1: Patient Check‑in', 'info'); state.autoDemoTimeoutIds.push(setTimeout(()=>runAutoDemoStep(1),2000)); },
                    ()=>{ state.currentStep=2; updateAllUI(); showToast('Step 2: AI Triage', 'info'); state.autoDemoTimeoutIds.push(setTimeout(()=>runAutoDemoStep(2),2000)); },
                    ()=>{ state.currentStep=3; updateAllUI(); showToast('Step 3: Token Queue', 'info'); state.autoDemoTimeoutIds.push(setTimeout(()=>runAutoDemoStep(3),2000)); },
                    ()=>{
                        if(state.waitingQueue.length===0){showToast('Queue empty. Demo complete.','success-toast');stopAutoDemo();return;}
                        state.currentStep=4; updateAllUI(); consultationPanel.classList.add('highlight-glow');
                        const patient=state.waitingQueue.shift(); state.currentPatient=patient; state.extractedMeds=[]; state.formVisible=false;
                        rxContent.innerHTML='<span style="color:#94A3B8;">Listening...</span>'; patientFormOverlay.classList.remove('visible');
                        patientNameInput.value='';patientAgeInput.value='';patientWhatsappInput.value='';sendReportBtn.disabled=true;
                        updateCurrentPatientCardUI();renderQueue();chatContainer.innerHTML='';chatPlaceholder.style.display='none';
                        state.isTranscribing=true;updateAllUI();showToast('Step 4: Live Consultation','info');
                        startTranscriptionForDemo(patient, ()=>{ if(state.autoDemoActive) state.autoDemoTimeoutIds.push(setTimeout(()=>runAutoDemoStep(4),800)); });
                    },
                    ()=>{
                        state.currentStep=5; updateAllUI(); patientFormOverlay.classList.add('visible'); state.formVisible=true;
                        if(state.currentPatient){patientNameInput.value=state.currentPatient.name; patientAgeInput.value=state.currentPatient.age;}
                        patientWhatsappInput.value='+91 98101 23456'; sendReportBtn.disabled=false; state.currentStep=6; updateAllUI();
                        showToast('Step 5–6: Send Report','info');
                        state.autoDemoTimeoutIds.push(setTimeout(()=>{ if(state.autoDemoActive) sendReportBtn.click(); state.autoDemoTimeoutIds.push(setTimeout(()=>{ if(state.autoDemoActive){ updateAllUI(); showToast('Full Process Complete!','success-toast'); state.autoDemoTimeoutIds.push(setTimeout(()=>stopAutoDemo(),3000)); } },2500)); },1600));
                    },
                ];
                if(stepIndex<steps.length) steps[stepIndex]();
            }
            function startTranscriptionForDemo(patient, callback) { /* similar to manual but with callback */ 
                state.isTranscribing=true; updateAllUI(); chatContainer.innerHTML='';
                const allWords=[]; mockScript.forEach(e=>{ const words=e.text.split(/\s+/); words.forEach((w,i)=>allWords.push({speaker:e.speaker,word:w,isFirst:i===0,fullLineText:e.text})); });
                let idx=0,currentBubble=null,currentSpeaker=null;
                function streamWord(){
                    if(!state.autoDemoActive){state.isTranscribing=false;updateAllUI();return;}
                    if(idx>=allWords.length){state.isTranscribing=false;state.currentStep=5;updateAllUI();consultationPanel.classList.remove('highlight-glow');updateRxWidget();if(callback)callback();return;}
                    const entry=allWords[idx];
                    if(entry.isFirst||entry.speaker!==currentSpeaker){currentSpeaker=entry.speaker;currentBubble=document.createElement('div');currentBubble.className='chat-bubble '+(entry.speaker==='Doctor'?'doctor':'patient');const l=document.createElement('span');l.className='speaker-label';l.textContent=entry.speaker==='Doctor'?'👨‍⚕️ Doctor':'🧑‍🦰 Patient';currentBubble.appendChild(l);const m=document.createElement('span');m.className='msg-text';currentBubble.appendChild(m);chatContainer.appendChild(currentBubble);}
                    const msg=currentBubble.querySelector('.msg-text'); const h=highlightEntity(entry.word);
                    if(h!==entry.word){const s=document.createElement('span');s.innerHTML=' '+h;msg.appendChild(s);extractMedFromWord(entry.word);}else{msg.appendChild(document.createTextNode(' '+entry.word));}
                    updateRxWidget();chatContainer.scrollTop=chatContainer.scrollHeight;idx++;
                    state.transcriptionTimeoutIds.push(setTimeout(streamWord,200+Math.random()*70));
                }
                state.transcriptionTimeoutIds.push(setTimeout(streamWord,300));
            }

            // ──────────────────────────────────────
            // RESET
            // ──────────────────────────────────────
            function resetEverything() { stopAutoDemo(); resetEverythingSilent(); showToast('🔄 Reset complete.', 'info'); }
            function resetEverythingSilent() {
                clearAllTranscriptionTimeouts(); state.autoDemoTimeoutIds.forEach(id=>clearTimeout(id)); state.autoDemoTimeoutIds=[];
                state.isTranscribing=false; state.autoDemoActive=false; state.currentPatient=null; state.extractedMeds=[]; state.formVisible=false; state.currentStep=1;
                state.waitingQueue=[ {token:12,name:'Ravi Singh',age:34,concern:'Persistent cough & fever',wait_time:'25 mins'},{token:13,name:'Anita Desai',age:52,concern:'Joint pain in knees',wait_time:'15 mins'},{token:14,name:'Vikram Patel',age:28,concern:'Allergic skin rash',wait_time:'5 mins'} ];
                chatContainer.innerHTML=''; chatPlaceholder.style.display='flex'; rxContent.innerHTML='<span style="color:#94A3B8;">Waiting for AI to extract prescription...</span>';
                patientFormOverlay.classList.remove('visible'); patientNameInput.value='';patientAgeInput.value='';patientWhatsappInput.value='';sendReportBtn.disabled=true;sendReportBtn.classList.remove('loading');
                consultationPanel.classList.remove('highlight-glow'); btnAutoDemo.textContent='▶️ Auto Demo'; btnAutoDemo.style.background='';btnAutoDemo.style.color='';
                updateCurrentPatientCardUI(); renderQueue(); updateAllUI();
                const dots=$$('.flow-dot-mini'); dots.forEach(d=>{d.classList.remove('done-dot','active-dot');}); if(dots[0])dots[0].classList.add('active-dot');
                flowStepLabel.textContent='1'; flowStepName.textContent='Patient Check‑in';
            }

            // ──────────────────────────────────────
            // TOAST
            // ──────────────────────────────────────
            function showToast(msg, type='info') {
                const t=document.createElement('div'); t.className='toast'+(type==='whatsapp-toast'?' whatsapp-toast':'')+(type==='success-toast'?' success-toast':'');
                t.innerHTML=msg; toastContainer.appendChild(t); setTimeout(()=>{if(t.parentNode)t.remove();},4300);
            }
            function addRipple(e){const b=e.currentTarget;const r=document.createElement('span');r.className='ripple-effect';const rect=b.getBoundingClientRect();const s=Math.max(rect.width,rect.height);r.style.width=s+'px';r.style.height=s+'px';r.style.left=(e.clientX-rect.left-s/2)+'px';r.style.top=(e.clientY-rect.top-s/2)+'px';b.appendChild(r);r.addEventListener('animationend',()=>r.remove());}

            init();
            console.log('🏥 Apollo Smart Clinic AI ready. Dashboard & Mind Map pages active.');
        });
    </script>
</body>
