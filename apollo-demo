            </button>
            <button class="btn-reset" id="btnReset" title="Reset entire demonstration">
                🔄 Reset
            </button>
        </div>
    </nav>

    <!-- ═══════════ PROCESS STEPPER ═══════════ -->
    <div class="process-stepper-container">
        <div class="process-stepper" id="processStepper">
            <div class="step-item active" data-step="1">
                <span class="step-num">1</span>📱 Patient Check‑in
            </div>
            <div class="step-connector"></div>
            <div class="step-item" data-step="2">
                <span class="step-num">2</span>🤖 AI Triage
            </div>
            <div class="step-connector"></div>
            <div class="step-item" data-step="3">
                <span class="step-num">3</span>🔢 Token Queue
            </div>
            <div class="step-connector"></div>
            <div class="step-item" data-step="4">
                <span class="step-num">4</span>👨‍⚕️ Live Consultation
            </div>
            <div class="step-connector"></div>
            <div class="step-item" data-step="5">
                <span class="step-num">5</span>💊 Prescription AI
            </div>
            <div class="step-connector"></div>
            <div class="step-item" data-step="6">
                <span class="step-num">6</span>📄 WhatsApp Report
            </div>
        </div>
    </div>

    <!-- ═══════════ MAIN LAYOUT ═══════════ -->
    <div class="main-container">
        <!-- LEFT COLUMN -->
        <div class="left-column">
            <!-- Consultation Panel -->
            <div class="panel" id="consultationPanel">
                <div class="panel-header">
                    <span class="panel-icon">🎙️</span>
                    <span class="panel-title">Live Consultation & AI Transcription</span>
                    <span class="panel-badge badge-idle" id="transcriptionBadge">⏸ Idle</span>
                </div>
                <div class="chat-container" id="chatContainer">
                    <div class="chat-placeholder" id="chatPlaceholder">
                        <i class="fa-solid fa-user-doctor"></i>
                        <span><strong>No active consultation yet.</strong></span>
                        <span style="font-size:0.7rem;">Click <strong>NEXT PATIENT</strong> or press <strong>▶ Auto Demo</strong> to see the full process.</span>
                    </div>
                </div>
                <div class="rx-widget" id="rxWidget">
                    <span style="font-size:0.85rem;">💊</span>
                    <span id="rxContent" style="color:#94A3B8;font-weight:400;">Waiting for AI to extract prescription...</span>
                </div>
            </div>

            <!-- Patient Form -->
            <div class="form-overlay" id="patientFormOverlay">
                <div style="font-weight:800;font-size:var(--font-lg);color:var(--apollo-navy);margin-bottom:0.7rem;">
                    📋 Finalize & Send Patient Report
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Patient Full Name</label>
                        <input type="text" id="patient_name" placeholder="e.g., Rajesh Kumar">
                    </div>
                    <div class="form-group" style="max-width:80px;">
                        <label>Age</label>
                        <input type="number" id="patient_age" placeholder="45" min="0" max="150">
                    </div>
                    <div class="form-group">
                        <label>WhatsApp Number (+country code)</label>
                        <input type="tel" id="patient_whatsapp" placeholder="+91 98765 43210">
                    </div>
                </div>
                <button class="btn btn-gold" id="sendReportBtn" style="margin-top:0.8rem;" disabled>
                    <span class="btn-spinner"></span>
                    🚀 Generate PDF & Send via WhatsApp
                </button>
            </div>
        </div>

        <!-- RIGHT COLUMN -->
        <div class="right-column">
            <!-- Current Patient Card -->
            <div class="patient-card empty-card" id="currentPatientCard">
                <div class="card-eyebrow">🪪 Currently Consulting</div>
                <div class="empty-state-text" id="currentPatientContent">Waiting for next patient...</div>
            </div>

            <!-- Queue Panel -->
            <div class="panel" style="padding-bottom:0.7rem;">
                <div class="panel-header" style="margin-bottom:0.4rem;">
                    <span class="panel-icon">📌</span>
                    <span class="panel-title">Waiting Queue <span style="font-weight:400;font-size:0.7rem;color:#64748B;">(Token System • नंबर लगाओ)</span></span>
                </div>
                <ul class="queue-list" id="queueList"></ul>
                <button class="btn-next-full" id="nextPatientBtn" style="margin-top:0.65rem;">
                    ⏩ CALL NEXT PATIENT
                </button>
            </div>

            <!-- Flow Diagram -->
            <div class="flow-diagram">
                <div class="flow-title">🔄 Process Flow</div>
                <div class="flow-steps-mini" id="flowMini">
                    <span class="flow-dot active-flow" data-fs="1"></span><span class="flow-arrow-mini">→</span>
                    <span class="flow-dot" data-fs="2"></span><span class="flow-arrow-mini">→</span>
                    <span class="flow-dot" data-fs="3"></span><span class="flow-arrow-mini">→</span>
                    <span class="flow-dot" data-fs="4"></span><span class="flow-arrow-mini">→</span>
                    <span class="flow-dot" data-fs="5"></span><span class="flow-arrow-mini">→</span>
                    <span class="flow-dot" data-fs="6"></span>
                </div>
                <div style="font-size:0.6rem;color:var(--gray-400);margin-top:0.35rem;">Step <span id="flowStepLabel">1</span> of 6 — <span id="flowStepName">Patient Check‑in</span></div>
            </div>
        </div>
    </div>

    <!-- ═══════════ TOAST CONTAINER ═══════════ -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // ──────────────────────────────────────
            // GLOBAL STATE
            // ──────────────────────────────────────
            const state = {
                currentStep: 1,
                currentPatient: null,
                waitingQueue: [
                    { token: 12, name: 'Ravi Singh', age: 34, concern: 'Persistent cough & fever',
                    wait_time: '25 mins' },
                    { token: 13, name: 'Anita Desai', age: 52, concern: 'Joint pain in knees',
                    wait_time: '15 mins' },
                    { token: 14, name: 'Vikram Patel', age: 28, concern: 'Allergic skin rash',
                    wait_time: '5 mins' },
                ],
                isTranscribing: false,
                transcriptionTimeoutIds: [],
                extractedMeds: [],
                formVisible: false,
                autoDemoActive: false,
                autoDemoTimeoutIds: [],
            };

            const mockScript = [
                { speaker: 'Doctor', text: 'Good morning, Mr. Ravi. Tell me about your symptoms.' },
                { speaker: 'Patient',
                    text: 'Doctor, 5 days se dry cough hai. Raat mein bohot takleef hoti hai. (5 days dry cough, worse at night.)'
                },
                { speaker: 'Doctor', text: 'Any fever or body pain?' },
                { speaker: 'Patient',
                    text: 'Haan, evening mein mild fever aata hai. (Yes, mild evening fever.)' },
                { speaker: 'Doctor',
                    text: 'I am prescribing Azithromycin 500mg once daily for 3 days. Also Paracetamol 650mg if fever exceeds 101°F.'
                },
                { speaker: 'Patient', text: 'Okay doctor. Aur kuch? (Anything else?)' },
                { speaker: 'Doctor',
                    text: 'Take warm fluids. Avoid cold items. I am also sharing a diet chart via WhatsApp.' },
            ];

            // ──────────────────────────────────────
            // DOM REFS
            // ──────────────────────────────────────
            const $ = (s) => document.querySelector(s);
            const $$ = (s) => document.querySelectorAll(s);

            const btnAutoDemo = $('#btnAutoDemo');
            const btnReset = $('#btnReset');
            const processStepper = $('#processStepper');
            const transcriptionBadge = $('#transcriptionBadge');
            const chatContainer = $('#chatContainer');
            const chatPlaceholder = $('#chatPlaceholder');
            const rxWidget = $('#rxWidget');
            const rxContent = $('#rxContent');
            const patientFormOverlay = $('#patientFormOverlay');
            const patientNameInput = $('#patient_name');
            const patientAgeInput = $('#patient_age');
            const patientWhatsappInput = $('#patient_whatsapp');
            const sendReportBtn = $('#sendReportBtn');
            const currentPatientCard = $('#currentPatientCard');
            const currentPatientContent = $('#currentPatientContent');
            const queueList = $('#queueList');
            const nextPatientBtn = $('#nextPatientBtn');
            const flowMini = $('#flowMini');
            const flowStepLabel = $('#flowStepLabel');
            const flowStepName = $('#flowStepName');
            const toastContainer = $('#toastContainer');
            const consultationPanel = $('#consultationPanel');

            const stepNames = ['Patient Check‑in', 'AI Triage', 'Token Queue', 'Live Consultation', 'Prescription AI',
                'WhatsApp Report'
            ];

            // ──────────────────────────────────────
            // INITIALIZATION
            // ──────────────────────────────────────
            function init() {
                renderQueue();
                updateAllUI();
                setupEventListeners();
                showToast('👋 Welcome! This is a <strong>full process demonstration</strong> of Apollo Smart Clinic AI. Click <strong>Auto Demo</strong> to watch all 6 steps.',
                    'info');
            }

            function setupEventListeners() {
                btnAutoDemo.addEventListener('click', toggleAutoDemo);
                btnReset.addEventListener('click', resetEverything);
                nextPatientBtn.addEventListener('click', handleNextPatient);
                nextPatientBtn.addEventListener('mousedown', addRipple);
                sendReportBtn.addEventListener('click', handleSendReport);
                sendReportBtn.addEventListener('mousedown', addRipple);
                patientWhatsappInput.addEventListener('input', () => {
                    sendReportBtn.disabled = !patientWhatsappInput.value.trim() || !state.currentPatient;
                });
                processStepper.addEventListener('click', function(e) {
                    const stepItem = e.target.closest('.step-item');
                    if (stepItem && !state.autoDemoActive) {
                        const step = parseInt(stepItem.dataset.step);
                        showToast(`📋 Step ${step}: <strong>${stepNames[step-1]}</strong> — This is a guided demo. Use Auto Demo to see the full flow.`,
                            'info');
                    }
                });
            }

            // ──────────────────────────────────────
            // STEPPER UI
            // ──────────────────────────────────────
            function updateStepper(activeStep) {
                const items = $$('.step-item');
                const connectors = $$('.step-connector');
                items.forEach((item, i) => {
                    const s = i + 1;
                    item.classList.remove('active', 'completed');
                    if (s < activeStep) item.classList.add('completed');
                    if (s === activeStep) item.classList.add('active');
                });
                connectors.forEach((conn, i) => {
                    if (i + 1 < activeStep) conn.classList.add('done');
                    else conn.classList.remove('done');
                });
                // Update flow mini diagram
                const dots = $$('.flow-dot');
                dots.forEach((dot, i) => {
                    const s = i + 1;
                    dot.classList.remove('active-flow', 'done-flow');
                    if (s < activeStep) dot.classList.add('done-flow');
                    if (s === activeStep) dot.classList.add('active-flow');
                });
                flowStepLabel.textContent = activeStep;
                flowStepName.textContent = stepNames[activeStep - 1];
                state.currentStep = activeStep;
            }

            function updateAllUI() {
                updateStepper(state.currentStep);
                updateNextButtonState();
                updateTranscriptionBadge();
                updateCurrentPatientCardUI();
            }

            function updateTranscriptionBadge() {
                if (state.isTranscribing) {
                    transcriptionBadge.textContent = '🔴 LIVE';
                    transcriptionBadge.className = 'panel-badge badge-live';
                } else if (state.currentPatient && !state.isTranscribing && state.formVisible) {
                    transcriptionBadge.textContent = '✅ Done';
                    transcriptionBadge.className = 'panel-badge badge-done';
                } else {
                    transcriptionBadge.textContent = '⏸ Idle';
                    transcriptionBadge.className = 'panel-badge badge-idle';
                }
            }

            function updateNextButtonState() {
                nextPatientBtn.disabled = state.waitingQueue.length === 0 || state.isTranscribing;
                if (state.waitingQueue.length === 0 && !state.currentPatient) {
                    nextPatientBtn.style.opacity = '0.45';
                } else if (state.isTranscribing) {
                    nextPatientBtn.style.opacity = '0.5';
                } else {
                    nextPatientBtn.style.opacity = '1';
                }
            }

            function updateCurrentPatientCardUI() {
                if (!state.currentPatient) {
                    currentPatientCard.classList.add('empty-card');
                    currentPatientContent.innerHTML =
                        '<div class="empty-state-text">Waiting for next patient...</div>';
                } else {
                    currentPatientCard.classList.remove('empty-card');
                    const p = state.currentPatient;
                    currentPatientContent.innerHTML = `
                        <div class="patient-name-lg">${p.name}</div>
                        <div class="patient-meta">
                            <span>🎂 Age: ${p.age}</span>
                            <span>🩺 ${p.concern}</span>
                            <span class="token-chip">Token #${p.token}</span>
                        </div>
                    `;
                }
            }

            // ──────────────────────────────────────
            // QUEUE
            // ──────────────────────────────────────
            function renderQueue() {
                queueList.innerHTML = '';
                if (state.waitingQueue.length === 0) {
                    queueList.innerHTML =
                        '<li style="text-align:center;color:#94A3B8;padding:1.5rem;font-style:italic;">All patients seen. Queue empty.</li>';
                } else {
                    state.waitingQueue.forEach((patient, index) => {
                        const li = document.createElement('li');
                        li.className = 'queue-item' + (index === 0 ? ' next-in-line' : '');
                        li.dataset.token = patient.token;
                        li.innerHTML = `
                            <span style="color:#CBD5E1;cursor:grab;font-size:0.8rem;">⋮⋮</span>
                            <span class="queue-token-num">#${patient.token}</span>
                            <div class="queue-info">
                                <div class="queue-name">${patient.name}</div>
                                <div class="queue-concern">${patient.concern}</div>
                            </div>
                            <span class="queue-wait-badge">⏱ ${patient.wait_time}</span>
                        `;
                        li.addEventListener('click', () => {
                            if (!state.isTranscribing && !state.autoDemoActive) {
                                loadSpecificPatient(patient.token);
                            }
                        });
                        queueList.appendChild(li);
                    });
                }
                updateNextButtonState();
            }

            // ──────────────────────────────────────
            // NEXT PATIENT
            // ──────────────────────────────────────
            function handleNextPatient() {
                if (state.isTranscribing) {
                    showToast('⚠️ Please wait — consultation is still recording.', 'info');
                    return;
                }
                if (state.waitingQueue.length === 0) {
                    showToast('📭 No more patients in the queue.', 'info');
                    return;
                }
                clearAllTranscriptionTimeouts();
                const patient = state.waitingQueue.shift();
                state.currentPatient = patient;
                state.extractedMeds = [];
                state.formVisible = false;
                rxContent.innerHTML =
                    '<span style="color:#94A3B8;font-weight:400;">Listening for prescription details...</span>';
                patientFormOverlay.classList.remove('visible');
                patientNameInput.value = '';
                patientAgeInput.value = '';
                patientWhatsappInput.value = '';
                sendReportBtn.disabled = true;
                sendReportBtn.classList.remove('loading');
                updateCurrentPatientCardUI();
                renderQueue();
                chatContainer.innerHTML = '';
                chatPlaceholder.style.display = 'none';
                state.isTranscribing = true;
                state.currentStep = 4;
                updateAllUI();
                consultationPanel.classList.add('highlight-panel');
                showToast(
                    `📱 <strong>WhatsApp Alert:</strong> Token #${patient.token} — "Your turn! Please proceed to Room 201." 🗺️ <em>Google Maps attached.</em>`,
                    'whatsapp-toast');
                startTranscription(patient);
            }

            function loadSpecificPatient(token) {
                const index = state.waitingQueue.findIndex(p => p.token === token);
                if (index === -1) return;
                clearAllTranscriptionTimeouts();
                const patient = state.waitingQueue.splice(index, 1)[0];
                state.currentPatient = patient;
                state.extractedMeds = [];
                state.formVisible = false;
                rxContent.innerHTML =
                    '<span style="color:#94A3B8;font-weight:400;">Listening for prescription details...</span>';
                patientFormOverlay.classList.remove('visible');
                patientNameInput.value = '';
                patientAgeInput.value = '';
                patientWhatsappInput.value = '';
                sendReportBtn.disabled = true;
                sendReportBtn.classList.remove('loading');
                updateCurrentPatientCardUI();
                renderQueue();
                chatContainer.innerHTML = '';
                chatPlaceholder.style.display = 'none';
                state.isTranscribing = true;
                state.currentStep = 4;
                updateAllUI();
                consultationPanel.classList.add('highlight-panel');
                showToast(
                    `📱 <strong>WhatsApp Alert:</strong> Token #${patient.token} — "Your turn! Please proceed to Room 201."`,
                    'whatsapp-toast');
                startTranscription(patient);
            }

            // ──────────────────────────────────────
            // TRANSCRIPTION
            // ──────────────────────────────────────
            function startTranscription(patient) {
                state.isTranscribing = true;
                updateAllUI();
                chatContainer.innerHTML = '';
                rxContent.innerHTML =
                    '<span style="color:#94A3B8;font-weight:400;">Listening for prescription details...</span>';
                const allWords = [];
                mockScript.forEach(entry => {
                    const words = entry.text.split(/\s+/);
                    words.forEach((w, idx) => {
                        allWords.push({ speaker: entry.speaker, word: w, isFirst: idx === 0 });
                    });
                });
                let idx = 0;
                let currentBubble = null;
                let currentSpeaker = null;

                function streamWord() {
                    if (idx >= allWords.length) {
                        finishTranscription(patient);
                        return;
                    }
                    const entry = allWords[idx];
                    if (entry.isFirst || entry.speaker !== currentSpeaker) {
                        currentSpeaker = entry.speaker;
                        currentBubble = document.createElement('div');
                        currentBubble.className = 'chat-bubble ' + (entry.speaker === 'Doctor' ? 'doctor' :
                            'patient');
                        const label = document.createElement('span');
                        label.className = 'speaker-label';
                        label.textContent = entry.speaker === 'Doctor' ? '👨‍⚕️ Doctor' : '🧑‍🦰 Patient';
                        currentBubble.appendChild(label);
                        const msgSpan = document.createElement('span');
                        msgSpan.className = 'msg-text';
                        currentBubble.appendChild(msgSpan);
                        chatContainer.appendChild(currentBubble);
                    }
                    const msgSpan = currentBubble.querySelector('.msg-text');
                    const highlighted = highlightEntity(entry.word);
                    if (highlighted !== entry.word) {
                        const span = document.createElement('span');
                        span.innerHTML = ' ' + highlighted;
                        msgSpan.appendChild(span);
                        extractMedFromWord(entry.word);
                    } else {
                        msgSpan.appendChild(document.createTextNode(' ' + entry.word));
                    }
                    updateRxWidget();
                    chatContainer.scrollTop = chatContainer.scrollHeight;
                    idx++;
                    const tid = setTimeout(streamWord, 260 + Math.random() * 90);
                    state.transcriptionTimeoutIds.push(tid);
                }
                const initTid = setTimeout(streamWord, 350);
                state.transcriptionTimeoutIds.push(initTid);
            }

            function highlightEntity(word) {
                const clean = word.replace(/[.,;:!?]+$/, '');
                const suffix = word.slice(clean.length);
                if (/\d+mg/i.test(clean) || /\d+ml/i.test(clean) || /\d+mcg/i.test(clean)) {
                    return `<mark class="entity-highlight" title="Dosage">${clean}</mark>${suffix}`;
                }
                if (/^(Azithromycin|Paracetamol|Amoxicillin|Ibuprofen|Cetirizine|Omeprazole|Metformin)$/i.test(clean)) {
                    return `<mark class="entity-highlight" title="Medicine">${clean}</mark>${suffix}`;
                }
                if (/^(once|twice|three\s+times)\s+daily$/i.test(clean) || /^daily$/i.test(clean)) {
                    return `<mark class="entity-highlight" title="Instruction">${clean}</mark>${suffix}`;
                }
                return word;
            }

            function extractMedFromWord(word) {
                const clean = word.replace(/[.,;:!?]+$/, '');
                const medMatch = clean.match(/^(Azithromycin|Paracetamol|Amoxicillin|Ibuprofen|Cetirizine)$/i);
                const doseMatch = clean.match(/^(\d+mg|\d+ml|\d+mcg)$/i);
                if (medMatch && !state.extractedMeds.find(m => m.name.toLowerCase() === medMatch[1].toLowerCase())) {
                    state.extractedMeds.push({ name: medMatch[1], dosage: '', instruction: '' });
                }
                if (doseMatch && state.extractedMeds.length > 0) {
                    const last = state.extractedMeds[state.extractedMeds.length - 1];
                    if (!last.dosage) last.dosage = doseMatch[1];
                }
                const freqMatch = clean.match(/^(once|twice|three\s+times)\s+daily\s+for\s+(\d+)\s+days?$/i);
                if (freqMatch && state.extractedMeds.length > 0) {
                    const last = state.extractedMeds[state.extractedMeds.length - 1];
                    last.instruction = freqMatch[0];
                }
            }

            function updateRxWidget() {
                if (state.extractedMeds.length === 0) {
                    rxContent.innerHTML =
                        '<span style="color:#94A3B8;font-weight:400;">Listening for prescription details...</span>';
                    return;
                }
                rxContent.innerHTML = state.extractedMeds.map(m => {
                    let t = `<span class="rx-pill">💊 <strong>${m.name}</strong>`;
                    if (m.dosage) t += ` ${m.dosage}`;
                    if (m.instruction) t += ` — ${m.instruction}`;
                    t += '</span>';
                    return t;
                }).join(' ');
            }

            function finishTranscription(patient) {
                state.isTranscribing = false;
                state.currentStep = 5;
                updateAllUI();
                clearAllTranscriptionTimeouts();
                consultationPanel.classList.remove('highlight-panel');
                updateRxWidget();
                showToast('✅ <strong>Transcription complete!</strong> Prescription extracted. Please fill the form to send the report.',
                    'success-toast');
                // Show form
                setTimeout(() => {
                    patientFormOverlay.classList.add('visible');
                    state.formVisible = true;
                    patientNameInput.value = patient.name || '';
                    patientAgeInput.value = patient.age || '';
                    patientWhatsappInput.value = '';
                    sendReportBtn.disabled = true;
                    sendReportBtn.classList.remove('loading');
                    state.currentStep = 6;
                    updateAllUI();
                    patientFormOverlay.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }, 600);
            }

            function clearAllTranscriptionTimeouts() {
                state.transcriptionTimeoutIds.forEach(id => clearTimeout(id));
                state.transcriptionTimeoutIds = [];
            }

            // ──────────────────────────────────────
            // SEND REPORT
            // ──────────────────────────────────────
            function handleSendReport() {
                if (!state.currentPatient) return;
                const whatsapp = patientWhatsappInput.value.trim();
                if (!whatsapp) {
                    showToast('⚠️ Please enter a valid WhatsApp number.', 'info');
                    return;
                }
                sendReportBtn.classList.add('loading');
                sendReportBtn.disabled = true;
                setTimeout(() => {
                    const pname = patientNameInput.value || state.currentPatient.name;
                    const page = patientAgeInput.value || state.currentPatient.age;
                    const pdfText = `
    ╔══════════════════════════════════╗
    ║   APOLLO HOSPITALS              ║
    ║   Smart Clinic AI - Prescription║
    ╚══════════════════════════════════╝
    Patient: ${pname}  |  Age: ${page}
    Token: #${state.currentPatient.token}
    Date: ${new Date().toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
    ────────────────────────────────────
    💊 PRESCRIPTION:
    ${state.extractedMeds.map(m => `• ${m.name} ${m.dosage} — ${m.instruction}`).join('\n') || 'See consultation transcript'}
    ────────────────────────────────────
    👨‍⚕️ Dr. Sharma | Apollo Hospitals
    📍 Room 201 | 📞 +91-XXXXXXXXXX
    🗺️ Google Maps: [Link]
    ────────────────────────────────────
    Generated by Apollo Smart Clinic AI
                    `.trim();
                    const blob = new Blob([pdfText], { type: 'application/pdf' });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download =
                        `Apollo_Prescription_${pname.replace(/\s+/g,'_')}_T${state.currentPatient.token}.pdf`;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                    sendReportBtn.classList.remove('loading');
                    sendReportBtn.disabled = false;
                    const masked = whatsapp.slice(0, 5) + '****' + whatsapp.slice(-2);
                    showToast(
                        `📄 <strong>PDF Report Generated!</strong> Sent via WhatsApp API to ${masked} ✅<br><small>Apollo Hospitals — Digital Report Delivery</small>`,
                        'whatsapp-toast');
                    patientFormOverlay.classList.remove('visible');
                    state.formVisible = false;
                    state.currentStep = 6;
                    updateAllUI();
                    // Mark complete
                    setTimeout(() => {
                        updateStepper(6);
                        $$('.step-item').forEach(item => {
                            if (parseInt(item.dataset.step) <= 6) item.classList.add(
                                'completed');
                        });
                        $$('.step-connector').forEach(c => c.classList.add('done'));
                        $$('.flow-dot').forEach(d => d.classList.add('done-flow'));
                        d.classList.remove('active-flow');
                    }, 300);
                }, 2000);
            }

            // ──────────────────────────────────────
            // AUTO DEMO
            // ──────────────────────────────────────
            function toggleAutoDemo() {
                if (state.autoDemoActive) {
                    stopAutoDemo();
                    return;
                }
                startAutoDemo();
            }

            function startAutoDemo() {
                state.autoDemoActive = true;
                btnAutoDemo.textContent = '⏸ Stop Demo';
                btnAutoDemo.classList.add('playing');
                showToast('▶️ <strong>Auto Demo Started!</strong> Watching all 6 steps of the Apollo Smart Clinic process...',
                    'info');
                resetEverythingSilent();
                runAutoDemoStep(0);
            }

            function stopAutoDemo() {
                state.autoDemoActive = false;
                btnAutoDemo.textContent = '▶️ Auto Demo';
                btnAutoDemo.classList.remove('playing');
                state.autoDemoTimeoutIds.forEach(id => clearTimeout(id));
                state.autoDemoTimeoutIds = [];
                clearAllTranscriptionTimeouts();
                state.isTranscribing = false;
                updateAllUI();
                consultationPanel.classList.remove('highlight-panel');
                showToast('⏸ Demo stopped. You can explore manually.', 'info');
            }

            function runAutoDemoStep(stepIndex) {
                if (!state.autoDemoActive) return;
                const steps = [
                    // Step 1: Patient Check-in
                    () => {
                        state.currentStep = 1;
                        updateAllUI();
                        consultationPanel.classList.remove('highlight-panel');
                        showToast(
                            '📱 <strong>Step 1:</strong> Patient scans QR code at reception. Check‑in via WhatsApp.',
                            'info');
                        const tid = setTimeout(() => runAutoDemoStep(1), 2200);
                        state.autoDemoTimeoutIds.push(tid);
                    },
                    // Step 2: AI Triage
                    () => {
                        state.currentStep = 2;
                        updateAllUI();
                        showToast(
                            '🤖 <strong>Step 2:</strong> AI bot captures patient name, age & concern automatically.',
                            'info');
                        const tid = setTimeout(() => runAutoDemoStep(2), 2200);
                        state.autoDemoTimeoutIds.push(tid);
                    },
                    // Step 3: Token Queue
                    () => {
                        state.currentStep = 3;
                        updateAllUI();
                        showToast(
                            '🔢 <strong>Step 3:</strong> Token generated. Patient added to waiting queue. <em>(नंबर लग गया)</em>',
                            'info');
                        const tid = setTimeout(() => runAutoDemoStep(3), 2200);
                        state.autoDemoTimeoutIds.push(tid);
                    },
                    // Step 4: Call next patient + transcribe
                    () => {
                        if (state.waitingQueue.length === 0) {
                            showToast('📭 Queue empty. Demo complete!', 'success-toast');
                            stopAutoDemo();
                            return;
                        }
                        state.currentStep = 4;
                        updateAllUI();
                        consultationPanel.classList.add('highlight-panel');
                        const patient = state.waitingQueue.shift();
                        state.currentPatient = patient;
                        state.extractedMeds = [];
                        state.formVisible = false;
                        rxContent.innerHTML =
                            '<span style="color:#94A3B8;font-weight:400;">Listening for prescription details...</span>';
                        patientFormOverlay.classList.remove('visible');
                        patientNameInput.value = '';
                        patientAgeInput.value = '';
                        patientWhatsappInput.value = '';
                        sendReportBtn.disabled = true;
                        sendReportBtn.classList.remove('loading');
                        updateCurrentPatientCardUI();
                        renderQueue();
                        chatContainer.innerHTML = '';
                        chatPlaceholder.style.display = 'none';
                        state.isTranscribing = true;
                        updateAllUI();
                        showToast(
                            '👨‍⚕️ <strong>Step 4:</strong> Doctor starts consultation. AI transcribes live...',
                            'info');
                        startTranscriptionForDemo(patient, () => {
                            if (!state.autoDemoActive) return;
                            const tid = setTimeout(() => runAutoDemoStep(4), 1000);
                            state.autoDemoTimeoutIds.push(tid);
                        });
                    },
                    // Step 5 & 6: Form fill & send
                    () => {
                        state.currentStep = 5;
                        updateAllUI();
                        patientFormOverlay.classList.add('visible');
                        state.formVisible = true;
                        if (state.currentPatient) {
                            patientNameInput.value = state.currentPatient.name;
                            patientAgeInput.value = state.currentPatient.age;
                        }
                        patientWhatsappInput.value = '+91 98101 23456';
                        sendReportBtn.disabled = false;
                        state.currentStep = 6;
                        updateAllUI();
                        patientFormOverlay.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                        showToast(
                            '📄 <strong>Step 5–6:</strong> Form auto‑filled. Clicking Send Report now...',
                            'info');
                        const tid = setTimeout(() => {
                            if (!state.autoDemoActive) return;
                            sendReportBtn.click();
                            const tid2 = setTimeout(() => {
                                if (!state.autoDemoActive) return;
                                updateStepper(6);
                                $$('.step-item').forEach(item => {
                                    if (parseInt(item.dataset.step) <= 6) item.classList
                                        .add('completed');
                                });
                                $$('.step-connector').forEach(c => c.classList.add('done'));
                                $$('.flow-dot').forEach(d => d.classList.add('done-flow'));
                                showToast(
                                    '🎉 <strong>Full Process Complete!</strong> All 6 steps demonstrated. Patient report delivered via WhatsApp.',
                                    'success-toast');
                                const tid3 = setTimeout(() => {
                                    stopAutoDemo();
                                }, 3000);
                                state.autoDemoTimeoutIds.push(tid3);
                            }, 2500);
                            state.autoDemoTimeoutIds.push(tid2);
                        }, 1800);
                        state.autoDemoTimeoutIds.push(tid);
                    },
                ];
                if (stepIndex < steps.length) {
                    steps[stepIndex]();
                }
            }

            function startTranscriptionForDemo(patient, callback) {
                state.isTranscribing = true;
                updateAllUI();
                chatContainer.innerHTML = '';
                rxContent.innerHTML =
                    '<span style="color:#94A3B8;font-weight:400;">Listening for prescription details...</span>';
                const allWords = [];
                mockScript.forEach(entry => {
                    const words = entry.text.split(/\s+/);
                    words.forEach((w, idx) => {
                        allWords.push({ speaker: entry.speaker, word: w, isFirst: idx === 0 });
                    });
                });
                let idx = 0;
                let currentBubble = null;
                let currentSpeaker = null;

                function streamWord() {
                    if (!state.autoDemoActive) {
                        state.isTranscribing = false;
                        updateAllUI();
                        return;
                    }
                    if (idx >= allWords.length) {
                        state.isTranscribing = false;
                        state.currentStep = 5;
                        updateAllUI();
                        consultationPanel.classList.remove('highlight-panel');
                        updateRxWidget();
                        if (callback) callback();
                        return;
                    }
                    const entry = allWords[idx];
                    if (entry.isFirst || entry.speaker !== currentSpeaker) {
                        currentSpeaker = entry.speaker;
                        currentBubble = document.createElement('div');
                        currentBubble.className = 'chat-bubble ' + (entry.speaker === 'Doctor' ? 'doctor' :
                            'patient');
                        const label = document.createElement('span');
                        label.className = 'speaker-label';
                        label.textContent = entry.speaker === 'Doctor' ? '👨‍⚕️ Doctor' : '🧑‍🦰 Patient';
                        currentBubble.appendChild(label);
                        const msgSpan = document.createElement('span');
                        msgSpan.className = 'msg-text';
                        currentBubble.appendChild(msgSpan);
                        chatContainer.appendChild(currentBubble);
                    }
                    const msgSpan = currentBubble.querySelector('.msg-text');
                    const highlighted = highlightEntity(entry.word);
                    if (highlighted !== entry.word) {
                        const span = document.createElement('span');
                        span.innerHTML = ' ' + highlighted;
                        msgSpan.appendChild(span);
                        extractMedFromWord(entry.word);
                    } else {
                        msgSpan.appendChild(document.createTextNode(' ' + entry.word));
                    }
                    updateRxWidget();
                    chatContainer.scrollTop = chatContainer.scrollHeight;
                    idx++;
                    const tid = setTimeout(streamWord, 200 + Math.random() * 70);
                    state.transcriptionTimeoutIds.push(tid);
                }
                const initTid = setTimeout(streamWord, 300);
                state.transcriptionTimeoutIds.push(initTid);
            }

            // ──────────────────────────────────────
            // RESET
            // ──────────────────────────────────────
            function resetEverything() {
                stopAutoDemo();
                resetEverythingSilent();
                showToast('🔄 <strong>Reset complete.</strong> All data restored to initial state.', 'info');
            }

            function resetEverythingSilent() {
                clearAllTranscriptionTimeouts();
                state.autoDemoTimeoutIds.forEach(id => clearTimeout(id));
                state.autoDemoTimeoutIds = [];
                state.isTranscribing = false;
                state.autoDemoActive = false;
                state.currentPatient = null;
                state.extractedMeds = [];
                state.formVisible = false;
                state.currentStep = 1;
                state.waitingQueue = [
                    { token: 12, name: 'Ravi Singh', age: 34, concern: 'Persistent cough & fever',
                        wait_time: '25 mins' },
                    { token: 13, name: 'Anita Desai', age: 52, concern: 'Joint pain in knees',
                    wait_time: '15 mins' },
                    { token: 14, name: 'Vikram Patel', age: 28, concern: 'Allergic skin rash',
                    wait_time: '5 mins' },
                ];
                chatContainer.innerHTML = '';
                chatPlaceholder.style.display = 'flex';
                rxContent.innerHTML =
                    '<span style="color:#94A3B8;font-weight:400;">Waiting for AI to extract prescription...</span>';
                patientFormOverlay.classList.remove('visible');
                patientNameInput.value = '';
                patientAgeInput.value = '';
                patientWhatsappInput.value = '';
                sendReportBtn.disabled = true;
                sendReportBtn.classList.remove('loading');
                consultationPanel.classList.remove('highlight-panel');
                btnAutoDemo.textContent = '▶️ Auto Demo';
                btnAutoDemo.classList.remove('playing');
                updateCurrentPatientCardUI();
                renderQueue();
                updateAllUI();
                updateStepper(1);
                $$('.step-item').forEach(item => item.classList.remove('completed'));
                $$('.step-connector').forEach(c => c.classList.remove('done'));
                $$('.flow-dot').forEach(d => {
                    d.classList.remove('done-flow', 'active-flow');
                });
                const firstDot = $$('.flow-dot')[0];
                if (firstDot) firstDot.classList.add('active-flow');
            }

            // ──────────────────────────────────────
            // TOAST
            // ──────────────────────────────────────
            function showToast(message, type = 'info') {
                const toast = document.createElement('div');
                toast.className = 'toast';
                if (type === 'whatsapp-toast') toast.classList.add('whatsapp-toast');
                if (type === 'success-toast') toast.classList.add('success-toast');
                toast.innerHTML = message;
                toastContainer.appendChild(toast);
                setTimeout(() => {
                    if (toast.parentNode) toast.remove();
                }, 4300);
            }

            // ──────────────────────────────────────
            // RIPPLE
            // ──────────────────────────────────────
            function addRipple(e) {
                const btn = e.currentTarget;
                const ripple = document.createElement('span');
                ripple.className = 'ripple-effect';
                const rect = btn.getBoundingClientRect();
                const size = Math.max(rect.width, rect.height);
                ripple.style.width = size + 'px';
                ripple.style.height = size + 'px';
                ripple.style.left = (e.clientX - rect.left - size / 2) + 'px';
                ripple.style.top = (e.clientY - rect.top - size / 2) + 'px';
                btn.appendChild(ripple);
                ripple.addEventListener('animationend', () => ripple.remove());
            }

            // ──────────────────────────────────────
            // INIT
            // ──────────────────────────────────────
            init();
            console.log('🏥 Apollo Hospitals Smart Clinic AI — Full Process Demonstration Ready');
            console.log('👆 Click "Auto Demo" to see the complete 6‑step workflow.');
            console.log('📱 Steps: Check‑in → AI Triage → Token Queue → Consultation → Prescription → WhatsApp Report');
            console.log('🌐 Designed for Apollo Hospitals | All 70+ Centers');
        });
    </script>
</body>
